# pnpm on Windows: hoist native/reflective deps so Prisma engine, Nest decorators,
# and reflect-metadata resolve cleanly under the isolated store.
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/*
public-hoist-pattern[]=*nestjs*
public-hoist-pattern[]=reflect-metadata
public-hoist-pattern[]=@node-rs/*
strict-peer-dependencies=false
auto-install-peers=true
