# ==========================================================================
# PRODUCTION environment template (Vercel frontend + Render backend).
# These values are set in each provider's dashboard — this file documents them.
# Never commit real secrets.
# ==========================================================================

NODE_ENV=production
TZ_DEFAULT=Asia/Kolkata
CURRENCY=INR

# --- Database: persistent free Postgres (Neon or Supabase) -----------------
# Use the POOLED connection string from Neon. Must include sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Auth ------------------------------------------------------------------
# Generate strong 32+ char secrets (Render can auto-generate these).
JWT_ACCESS_SECRET=please-generate-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=please-generate-another-long-random-secret
JWT_REFRESH_TTL=30d
# IMPORTANT: leave empty. The browser only sees the Vercel origin (it reaches
# the API through Next's server-side /api proxy), so the auth cookie must be
# host-only — NOT pinned to the Render domain.
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# --- API / Web -------------------------------------------------------------
# WEB_ORIGIN = your Vercel URL (used for CORS on any direct cross-origin call).
WEB_ORIGIN=https://your-app.vercel.app
API_GLOBAL_PREFIX=api
# API_PORT is ignored on Render (it injects $PORT); kept for local runs.
API_PORT=4000
THROTTLE_TTL_SEC=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=8

# --- Queue (pg-boss on the same Postgres) ----------------------------------
PGBOSS_SCHEMA=pgboss

# --- Scheduled sweep -------------------------------------------------------
REMINDER_OFFSET_DAYS=10
OVERDUE_GRACE_DAYS=0
ESCALATION_OFFSET_DAYS=10
DAILY_SWEEP_CRON=0 6 * * *

# --- Email -----------------------------------------------------------------
# dev = writes .eml files (no real delivery). For real email set MAIL_TRANSPORT=smtp
# and the SMTP_* vars (Gmail: smtp.gmail.com:465, App Password, SMTP_SECURE=true).
EMAIL_PROVIDER=smtp_imap
MAIL_TRANSPORT=dev
MAIL_FROM=School Fees Office <fees@yourschool.com>
MAIL_REPLY_TO=fees@yourschool.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

# --- Dev endpoints: MUST be false in production ----------------------------
DEV_ENDPOINTS_ENABLED=false

# --- Seed credentials (only used when you run db:seed:ci once) --------------
SEED_ADMIN_EMAIL=admin@yourschool.com
SEED_ADMIN_PASSWORD=change-this-strong-password
SEED_ACCOUNTANT_EMAIL=accountant@yourschool.com
SEED_ACCOUNTANT_PASSWORD=change-this-strong-password

# ==========================================================================
# On Vercel (frontend, apps/web) set ONE variable:
#   API_URL=https://school-portal-backend.onrender.com
# (Next.js proxies /api/* to it — keeps auth cookies same-origin.)
# ==========================================================================
