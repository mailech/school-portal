{
  "name": "@app/db",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": ["index.js", "index.d.ts", "factory.js", "factory.d.ts", "generated", "prisma"],
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "build": "prisma generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "@node-rs/argon2": "^2.0.2",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "luxon": "^3.5.0",
    "@types/luxon": "^3.4.2"
  }
}
