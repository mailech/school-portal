# ==========================================================================
# School Fee-Dues Portal — environment (single source of truth)
# Copy to `.env` and fill in. Never commit `.env`.
# ==========================================================================

NODE_ENV=development
TZ_DEFAULT=Asia/Kolkata
CURRENCY=INR

# --- Database (native Postgres 16; no Docker/Redis required) --------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolportal?schema=public

# --- Auth ------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# --- API / Web -------------------------------------------------------------
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
API_GLOBAL_PREFIX=api
THROTTLE_TTL_SEC=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=8

# --- Queue (pg-boss on Postgres) ------------------------------------------
PGBOSS_SCHEMA=pgboss
PGBOSS_ARCHIVE_COMPLETED_AFTER_SEC=86400
PGBOSS_DELETE_AFTER_DAYS=7

# --- Scheduled sweep (defaults; AppSetting in DB wins at runtime) ----------
REMINDER_OFFSET_DAYS=10
OVERDUE_GRACE_DAYS=0
ESCALATION_OFFSET_DAYS=10
DAILY_SWEEP_CRON=0 6 * * *

# --- Email provider selection ---------------------------------------------
# smtp_imap = Nodemailer SMTP out + IMAP in (default, local-first)
# gmail_api = Gmail API (users.watch + Pub/Sub) — fill Gmail block below
EMAIL_PROVIDER=smtp_imap
# dev = Ethereal/stream transport (zero infra, prints preview URLs)
# smtp = real SMTP host below
MAIL_TRANSPORT=dev
MAIL_FROM=School Fees Office <fees@school.test>
MAIL_REPLY_TO=fees@school.test

# SMTP (outbound) — used when MAIL_TRANSPORT=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# IMAP (inbound) — used when EMAIL_PROVIDER=smtp_imap and IMAP creds present
IMAP_ENABLED=false
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true
IMAP_POLL_CRON=*/2 * * * *
IMAP_MAILBOX=INBOX

# Gmail API (used when EMAIL_PROVIDER=gmail_api)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=
GMAIL_TOPIC=
GMAIL_PUBSUB_VERIFICATION_TOKEN=

# --- Dev-only helpers ------------------------------------------------------
# Enables POST /api/dev/simulate-reply so the reply->yellow flow is demoable
# without any mail server. MUST be false in production.
DEV_ENDPOINTS_ENABLED=true

# --- Seed dev credentials (used by db:seed only) ---------------------------
SEED_ADMIN_EMAIL=admin@school.test
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ACCOUNTANT_EMAIL=accountant@school.test
SEED_ACCOUNTANT_PASSWORD=Account@12345
